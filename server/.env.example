# Environment Variables
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/civic_sense_db?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
# Option 1: Use service account key file path
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
# Option 2: Use service account JSON string (for production/Railway)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Development mode (skip Firebase auth for testing)
SKIP_FIREBASE_AUTH=false

# Cloudinary (for image uploads — free tier: 25 GB)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI Service URL
AI_SERVICE_URL=http://localhost:8000
# Production: AI_SERVICE_URL=https://your-ai-service.render.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://your-app.vercel.app

# Groq API — used by the chat assistant to produce natural-language answers
# Get a free key at https://console.groq.com
# Without this key the chatbot falls back to basic template responses.
GROQ_API_KEY=your_groq_api_key_here
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
