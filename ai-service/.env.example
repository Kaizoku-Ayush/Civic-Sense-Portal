# AI Microservice Environment Variables

# Groq API Key — get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model to use for Groq vision analysis (default: meta-llama/llama-4-scout-17b-16e-instruct)
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Port (default: 8000)
PORT=8000

# Environment
ENV=development
